{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "OMNIPULSE Next.js TSConfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2022",
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    },
    "allowJs": true
  }
}
