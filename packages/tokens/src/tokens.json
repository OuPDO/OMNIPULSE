{
  "$description": "OMNIPULSE Design Tokens — ObladenMedia Brand (DTCG Format)",
  "$source": "ObladenMedia Brand Guidelines + TweakCN Theme",
  "color": {
    "brand": {
      "$type": "color",
      "$description": "Primäre Markenfarben — ObladenMedia Corporate Identity",
      "graphite-mist": {
        "$value": "#40454D",
        "$description": "Primary: Text, dunkle Hintergründe, Logo Default"
      },
      "golden-saffron": {
        "$value": "#F5C754",
        "$description": "Accent: CTAs, Buttons, Highlights"
      },
      "coral-blaze": {
        "$value": "#F55F52",
        "$description": "Destructive/Error ONLY: Delete, Fehler, Validierung"
      },
      "fresh-meadow": {
        "$value": "#64BD79",
        "$description": "Success ONLY: Erfolg, Bestätigungen, Wachstum"
      },
      "aqua-sky": {
        "$value": "#6DB2CC",
        "$description": "Links, Info, General UI Accent, Hover/Selection"
      }
    },
    "neutral": {
      "$type": "color",
      "white": { "$value": "#FFFFFF" },
      "off-white": { "$value": "#F8F9FA" },
      "border-light": { "$value": "#E2E4E8" },
      "muted": { "$value": "#9CA3AF" },
      "graphite-light": { "$value": "#5A5F67" },
      "graphite-dark": { "$value": "#2F3338" }
    },
    "semantic": {
      "$type": "color",
      "$description": "shadcn/ui Semantic Mapping",
      "primary": { "$value": "#F5C754" },
      "primary-foreground": { "$value": "#40454D" },
      "secondary": { "$value": "#40454D" },
      "secondary-foreground": { "$value": "#FFFFFF" },
      "accent": { "$value": "#C7E0EA" },
      "accent-foreground": { "$value": "#40454D" },
      "destructive": { "$value": "#F55F52" },
      "destructive-foreground": { "$value": "#FFFFFF" },
      "success": { "$value": "#64BD79" },
      "success-foreground": { "$value": "#FFFFFF" },
      "background": { "$value": "#FAFAFA" },
      "foreground": { "$value": "#40454D" },
      "card": { "$value": "#FFFFFF" },
      "card-foreground": { "$value": "#40454D" },
      "muted": { "$value": "#F1F2F3" },
      "muted-foreground": { "$value": "#6B7280" },
      "border": { "$value": "#E2E4E8" },
      "input": { "$value": "#E2E4E8" },
      "ring": { "$value": "#F5C754" }
    },
    "chart": {
      "$type": "color",
      "$description": "Datenvisualisierung — in dieser Reihenfolge nutzen",
      "1": { "$value": "#F5C754" },
      "2": { "$value": "#40454D" },
      "3": { "$value": "#6DB2CC" },
      "4": { "$value": "#64BD79" },
      "5": { "$value": "#F55F52" }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "heading": {
      "$value": ["Montserrat", "Arial", "Helvetica", "sans-serif"],
      "$description": "Headings, Navigation, Buttons, Labels — SemiBold 600"
    },
    "body": {
      "$value": ["Merriweather Sans", "Open Sans", "Arial", "sans-serif"],
      "$description": "Fließtext, Beschreibungen, Formularfelder — Regular 400"
    },
    "accent": {
      "$value": ["Caveat", "Indie Flower", "cursive"],
      "$description": "Handschrift-Akzente — sparsam, nie Fließtext, ab 40px"
    },
    "mono": {
      "$value": ["ui-monospace", "SFMono-Regular", "monospace"],
      "$description": "Code-Blöcke"
    }
  },
  "fontSize": {
    "$type": "dimension",
    "xs": { "$value": "0.75rem" },
    "sm": { "$value": "0.875rem" },
    "base": { "$value": "1rem" },
    "lg": { "$value": "1.125rem" },
    "xl": { "$value": "1.25rem" },
    "2xl": { "$value": "1.5rem" },
    "3xl": { "$value": "1.875rem" },
    "4xl": { "$value": "2.25rem" },
    "5xl": { "$value": "3rem" }
  },
  "spacing": {
    "$type": "dimension",
    "base": { "$value": "0.25rem" },
    "0": { "$value": "0" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" },
    "20": { "$value": "5rem" },
    "24": { "$value": "6rem" }
  },
  "borderRadius": {
    "$type": "dimension",
    "base": { "$value": "0.5rem" },
    "sm": { "$value": "calc(0.5rem - 4px)" },
    "md": { "$value": "calc(0.5rem - 2px)" },
    "lg": { "$value": "0.5rem" },
    "xl": { "$value": "calc(0.5rem + 4px)" },
    "full": { "$value": "9999px" }
  },
  "shadow": {
    "$type": "shadow",
    "$description": "Schatten basierend auf OM-GraphiteMist",
    "color": { "$value": "#40454D" },
    "sm": { "$value": "0 1px 6px -1px rgba(64, 69, 77, 0.1)" },
    "md": { "$value": "0 1px 6px -1px rgba(64, 69, 77, 0.1), 0 2px 4px -2px rgba(64, 69, 77, 0.1)" },
    "lg": { "$value": "0 1px 6px -1px rgba(64, 69, 77, 0.1), 0 4px 6px -2px rgba(64, 69, 77, 0.1)" }
  }
}
