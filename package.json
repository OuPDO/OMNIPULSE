{
  "name": "omnipulse",
  "version": "0.1.0",
  "private": true,
  "description": "OMNIPULSE — Zentrale Plattform der ObladenMedia Agentur",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@omnipulse/web",
    "dev:mobile": "turbo run dev --filter=@omnipulse/mobile",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "tokens:build": "turbo run build --filter=@omnipulse/tokens",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0"
  }
}
